# Dockerfile para {{project_meta.name}}

{{#if (eq tech_stack.backend.runtime "Node.js")}}
FROM node:18-alpine

WORKDIR /app

COPY backend/package*.json ./
RUN npm ci --only=production

COPY backend/ .

EXPOSE 3001

CMD ["node", "server.js"]
{{/if}}

{{#if (eq tech_stack.backend.runtime "Python")}}
FROM python:3.11-slim

WORKDIR /app

COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY backend/ .

EXPOSE 8000

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
{{/if}}

{{#if (eq tech_stack.frontend.framework "React")}}
# Si es solo frontend, podemos usar nginx
FROM nginx:alpine
COPY frontend/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/nginx.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
{{/if}}
