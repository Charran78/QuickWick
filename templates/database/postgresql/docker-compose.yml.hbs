version: '3.8'

services:
  postgres:
    image: postgres:15
    container_name: {{project_meta.name}}-postgres
    environment:
      POSTGRES_DB: {{project_meta.name}}
      POSTGRES_USER: user
      POSTGRES_PASSWORD: password
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ./schema.sql:/docker-entrypoint-initdb.d/schema.sql

volumes:
  postgres_data:
